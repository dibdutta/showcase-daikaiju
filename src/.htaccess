<IfModule mod_rewrite.c>
RewriteEngine On

# If the request is for an existing directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If the request is for an existing file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve sitemap.xml from sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# SEO-friendly poster detail URLs: /poster/{id}/{slug}
RewriteRule ^poster/(\d+)/([^/]*)/?$ buy.php?mode=poster_details&auction_id=$1&poster_slug=$2 [QSA,L]
RewriteRule ^poster/(\d+)/?$ buy.php?mode=poster_details&auction_id=$1 [QSA,L]

# If request + .php exists, rewrite internally
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]
</IfModule>
