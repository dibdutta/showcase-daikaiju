{
  "family": "showcase-prod-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::263180773284:role/showcase-prod-ecs-execution",
  "taskRoleArn": "arn:aws:iam::263180773284:role/showcase-prod-ecs-task",
  "containerDefinitions": [
    {
      "name": "showcase-web",
      "image": "PLACEHOLDER_IMAGE",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "CDN_STATIC_URL", "value": "https://mygodzillashop.com" }
      ],
      "secrets": [
        { "name": "DB_SERVER", "valueFrom": "arn:aws:ssm:us-east-1:263180773284:parameter/showcase/prod/DB_SERVER" },
        { "name": "DB_NAME", "valueFrom": "arn:aws:ssm:us-east-1:263180773284:parameter/showcase/prod/DB_NAME" },
        { "name": "DB_USER", "valueFrom": "arn:aws:ssm:us-east-1:263180773284:parameter/showcase/prod/DB_USER" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:263180773284:parameter/showcase/prod/DB_PASSWORD" }
      ],
      "mountPoints": [
        { "sourceVolume": "sessions", "containerPath": "/var/www/html/sessions" },
        { "sourceVolume": "poster-photo", "containerPath": "/var/www/html/poster_photo" },
        { "sourceVolume": "templates-c", "containerPath": "/var/www/html/templates_c" },
        { "sourceVolume": "admin-templates-c", "containerPath": "/var/www/html/admin_templates_c" },
        { "sourceVolume": "bulkupload", "containerPath": "/var/www/html/bulkupload" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/showcase-prod-web",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "sessions",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-02c1121e2e2129208",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0802c65839d46b3d6",
          "iam": "ENABLED"
        }
      }
    },
    {
      "name": "poster-photo",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-02c1121e2e2129208",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-02515abb58dc82d99",
          "iam": "ENABLED"
        }
      }
    },
    {
      "name": "templates-c",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-02c1121e2e2129208",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-09065d1ba0976d8d9",
          "iam": "ENABLED"
        }
      }
    },
    {
      "name": "admin-templates-c",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-02c1121e2e2129208",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-02ccec884c23ccd27",
          "iam": "ENABLED"
        }
      }
    },
    {
      "name": "bulkupload",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-02c1121e2e2129208",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-09066cdf3fdd9149a",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
